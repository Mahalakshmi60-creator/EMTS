# PostgreSQL Connection configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/securevault

# Cryptographic Salt / AES-256 Key for database vault encryption.
# Generate a new URL-Safe base64 key using:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-urlsafe-base64-fernet-key-here

# JWT authentication signing secret key.
JWT_SECRET=super-secret-vault-key-jwt-signing-12345

# Google Gemini API key for AI Scanner
# Register and download from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSy...
